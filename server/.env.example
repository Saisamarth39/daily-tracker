PORT=5000
DATABASE_URL="postgresql://user:password@host.region.db.render.com/dbname"
JWT_SECRET="generate-a-strong-secret-key-here"
CLIENT_URL="https://your-vercel-app-url.vercel.app"

# Web Push VAPID Keys
# Generate these using: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY="your-public-key"
VAPID_PRIVATE_KEY="your-private-key"
VAPID_EMAIL="mailto:admin@yourdomain.com"
